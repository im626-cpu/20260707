# Supabase 프로젝트 설정 > Database 에서 확인 (Connection pooling / Direct connection)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase 프로젝트 설정 > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# 학교 이메일 인증 화이트리스트 (쉼표로 구분, @ 제외한 도메인만)
ALLOWED_EMAIL_DOMAINS="example.ac.kr"

# 모임 생성/매칭 완료 알림 이메일 (resend.com 에서 발급)
RESEND_API_KEY=""
# 알림을 받을 주소
NOTIFICATION_EMAIL=""
# 선택: 발신 주소. 커스텀 도메인을 Resend에 인증하지 않았다면 기본값(onboarding@resend.dev) 사용
RESEND_FROM_EMAIL="onboarding@resend.dev"
# 선택: 이메일 내 모임 링크에 사용할 배포 도메인 (미설정 시 http://localhost:3000)
NEXT_PUBLIC_SITE_URL=""
